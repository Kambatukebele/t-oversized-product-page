<style>
  /* ============================================
     STICKY ADD TO CART BAR
     ============================================ */

   .sticky-atc-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: white;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0 -0.4rem 1.6rem rgba(var(--color-foreground), 0.06);

    /* Hidden by default — JS will toggle this */
    transform: translateY(100%);
    transition: transform 0.3s ease;
    visibility: hidden;
  }

  /* Visible state toggled by JS */
  .sticky-atc-bar.is-visible {
    transform: translateY(0);
    visibility: visible;
  }

  .sticky-atc-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1.2rem;
    padding-bottom: 1.2rem;
  }

  /* Product info block */
  .sticky-atc-bar__product-info {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex: 1;
    min-width: 0; /* prevents flex overflow */
  }

  .sticky-atc-bar__thumbnail {
    flex-shrink: 0;
    width: 6rem;
    height: 6rem;
    border-radius: var(--media-radius);
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.04);
  }

  .sticky-atc-bar__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sticky-atc-bar__meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .sticky-atc-bar__title {
    font-size: 1.4rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .sticky-atc-bar__variant {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.6);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Price */
  .sticky-atc-bar__price {
    font-size: 1.6rem;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* CTA */
  .sticky-atc-bar__actions {
    flex-shrink: 0;
  }

   .sticky-atc-bar__button {
    white-space: nowrap;
    min-width: 14rem;
  }

  /* ============================================
     RESPONSIVE — collapse info on mobile
     ============================================ */

   @media screen and (max-width: 749px) {
    .sticky-atc-bar__product-info {
      display: none; /* hide on small screens, just show button */
    }

    .sticky-atc-bar__price {
      display: none;
    }

    .sticky-atc-bar__inner {
      justify-content: center;
    }

    .sticky-atc-bar__button {
      width: 100%;
      max-width: 40rem;
    }
</style>

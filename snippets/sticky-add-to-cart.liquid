<script src="{{ "sticky-add-to-cart.js" | asset_url }}" defer></script>

<sticky-add-to-cart>
  <div id="sticky-atc-bar" class="sticky-atc-bar" aria-hidden="true">
    <div class="sticky-atc-bar__inner page-width">
